<robot name="articubot_robot">
  <!-- ============================================================ -->
  <!-- 材质定义 (Materials)                                          -->
  <!-- ============================================================ -->
  <!-- 机器人主体：蓝色金属质感 -->
  <material name="robot_blue">
    <color rgba="0.15 0.35 0.85 1.0"/>
  </material>
  <!-- 轮子：深灰色 -->
  <material name="wheel_dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <!-- 随动轮：深灰色 -->
  <material name="caster_grey">
    <color rgba="0.25 0.25 0.25 1.0"/>
  </material>
  <!-- 激光雷达：深灰色 -->
  <material name="lidar_dark">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <!-- 地面：灰色水泥质感 (用于RViz预览) -->
  <material name="ground_grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <!-- 障碍物：黑色塑料质感 (用于RViz预览) -->
  <material name="obstacle_black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <!-- 主体质量 (kg) -->
  <!-- ============================================================ -->
  <!-- 主体 (base_link)                                              -->
  <!-- 尺寸: 0.5m x 0.3m x 0.25m                                    -->
  <!-- ============================================================ -->
  <link name="base_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.125"/>
      <geometry>
        <box size="0.5 0.3 0.25"/>
      </geometry>
      <material name="robot_blue"/>
    </visual>
    <!-- 碰撞体抬高0.05m离地, 避免车身底盘拖地(否则严重阻碍旋转); 视觉体仍为规范0.25高 -->
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.15"/>
      <geometry>
        <box size="0.5 0.3 0.20"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.125"/>
      <mass value="1.5"/>
      <inertia ixx="0.0190625" ixy="0.0" ixz="0.0" iyy="0.0390625" iyz="0.0" izz="0.0425"/>
    </inertial>
  </link>
  <!-- ============================================================ -->
  <!-- 左驱动轮 (left_wheel_link)                                    -->
  <!-- 直径: 0.15m, 宽度: 0.05m, 中心: (0.15, 0.175, 0.075)        -->
  <!-- ============================================================ -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin rpy="1.5707963267948966 0 0" xyz="0.15 0.175 0.075"/>
    <axis xyz="0 0 -1"/>
  </joint>
  <link name="left_wheel_link">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.075"/>
      </geometry>
      <material name="wheel_dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.05" radius="0.075"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0003229166666666666" ixy="0.0" ixz="0.0" iyy="0.0003229166666666666" iyz="0.0" izz="0.0005625"/>
    </inertial>
  </link>
  <!-- ============================================================ -->
  <!-- 右驱动轮 (right_wheel_link)                                   -->
  <!-- 直径: 0.15m, 宽度: 0.05m, 中心: (0.15, -0.175, 0.075)       -->
  <!-- ============================================================ -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin rpy="1.5707963267948966 0 0" xyz="0.15 -0.175 0.075"/>
    <axis xyz="0 0 -1"/>
  </joint>
  <link name="right_wheel_link">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.075"/>
      </geometry>
      <material name="wheel_dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.05" radius="0.075"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0003229166666666666" ixy="0.0" ixz="0.0" iyy="0.0003229166666666666" iyz="0.0" izz="0.0005625"/>
    </inertial>
  </link>
  <!-- ============================================================ -->
  <!-- 随动轮 (caster_wheel_link)                                    -->
  <!-- 直径: 0.10m, 宽度: 0.05m, 中心: (-0.15, 0, 0.05)            -->
  <!-- 固定关节 (fixed joint)                                        -->
  <!-- ============================================================ -->
  <joint name="caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel_link"/>
    <origin rpy="1.5707963267948966 0 0" xyz="-0.15 0.0 0.05"/>
  </joint>
  <link name="caster_wheel_link">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.05"/>
      </geometry>
      <material name="caster_grey"/>
    </visual>
    <!-- 碰撞体用球面: 随动轮无法转向, 球面可在各方向自由滑动, 避免阻碍小车旋转 -->
    <collision>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="8.333333333333336e-05" ixy="0.0" ixz="0.0" iyy="8.333333333333336e-05" iyz="0.0" izz="0.00012500000000000003"/>
    </inertial>
  </link>
  <!-- ============================================================ -->
  <!-- 激光雷达 (laser_link)                                         -->
  <!-- 安装在主体顶部中心: (0, 0, 0.25)                               -->
  <!-- ============================================================ -->
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin rpy="0 0 0" xyz="0.0 0.0 0.26"/>
  </joint>
  <link name="laser_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.03" radius="0.04"/>
      </geometry>
      <material name="lidar_dark"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.03" radius="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0.0" ixz="0.0" iyy="0.000001" iyz="0.0" izz="0.000001"/>
    </inertial>
  </link>
  <!-- 差速驱动插件 -->
  <gazebo>
    <plugin filename="libgazebo_ros_diff_drive.so" name="diff_drive">
      <ros>
        <namespace>/</namespace>
      </ros>
      <update_rate>50</update_rate>
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.35</wheel_separation>
      <wheel_diameter>0.15</wheel_diameter>
      <max_wheel_torque>50.0</max_wheel_torque>
      <max_wheel_acceleration>10.0</max_wheel_acceleration>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <covariance_x>0.0001</covariance_x>
      <covariance_y>0.0001</covariance_y>
      <covariance_yaw>0.001</covariance_yaw>
    </plugin>
  </gazebo>
  <!-- 关节状态发布插件: 发布驱动轮真实角速度到 /joint_states -->
  <gazebo>
    <plugin filename="libgazebo_ros_joint_state_publisher.so" name="joint_states">
      <ros>
        <namespace>/</namespace>
      </ros>
      <update_rate>30</update_rate>
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>
  </gazebo>
  <!-- 2D激光雷达 - 单线360度水平扫描 -->
  <gazebo reference="laser_link">
    <sensor name="laser_sensor" type="ray">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <visualize>true</visualize>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>6.283185307179586</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.1</min>
          <max>5.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin filename="libgazebo_ros_ray_sensor.so" name="laser_plugin">
        <!-- ROS2 ray_sensor 默认发布到 ~/out, 通过 remapping 输出到 /scan (作业要求话题名) -->
        <ros>
          <namespace>/</namespace>
          <remapping>~/out:=/scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>laser_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>
  <!-- 材质 -->
  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
  </gazebo>
  <gazebo reference="left_wheel_link">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
  </gazebo>
  <gazebo reference="right_wheel_link">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
  </gazebo>
  <gazebo reference="caster_wheel_link">
    <material>Gazebo/DarkGrey</material>
    <!-- 随动轮球面碰撞体设为无摩擦, 让小车旋转时不被随动轮拖拽 -->
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>
  <gazebo reference="laser_link">
    <material>Gazebo/Black</material>
  </gazebo>
</robot>
